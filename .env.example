# ===========================================
# Miami Auto Detailing - Environment Variables
# ===========================================

# Supabase Configuration
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# GoHighLevel CRM Integration
# Get API key from: GHL → Settings → Business Profile → API Keys
VITE_GHL_API_KEY=your-gohighlevel-api-key
VITE_GHL_LOCATION_ID=your-ghl-location-id
VITE_GHL_PIPELINE_ID=your-ghl-pipeline-id
VITE_GHL_STAGE_ID=your-ghl-first-stage-id

# Email Notifications
# Can use any email API: SendGrid, Mailgun, Resend, etc.
VITE_EMAIL_API_URL=https://api.resend.com/emails
VITE_EMAIL_API_KEY=re_your_api_key
VITE_BUSINESS_EMAIL=info@miamidetailing.com

# Google Business Profile
VITE_GOOGLE_PLACE_ID=your-google-place-id
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key